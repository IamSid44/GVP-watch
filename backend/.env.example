# GVP Watch Backend - Environment Configuration
# ===============================================
# Copy this file to .env and fill in your actual values
# Do NOT commit .env to version control

# ===========================
# WHATSAPP API CONFIGURATION
# ===========================

# Your WhatsApp Business Account Access Token
# Get from: Meta Business Manager > System Users > Apps > WhatsApp
# Looks like: "EAABs8jn3n0gBAPk9xYZCZC3nWxW7RN..."
WHATSAPP_TOKEN=your_whatsapp_api_token_here

# Webhook Verification Token (arbitrary string, any value works)
# Must match the token configured in Meta Developer Portal
# Webhook Settings > Verify Token
VERIFY_TOKEN=your_webhook_verification_token

# Your WhatsApp Business Phone Number ID
# Get from: Meta Business Manager > WhatsApp > Phone Numbers
# Looks like: "102345678901234"
PHONE_NUMBER_ID=your_phone_number_id

# Your WhatsApp Business Account ID
# Get from: Meta Business Manager > WhatsApp > Business Account
# Looks like: "102345678901234"
BUSINESS_ACCOUNT_ID=your_business_account_id

# Optional: Default officer phone for fallback
# Format: International (e.g., +919876543210 or 919876543210)
OFFICER_PHONE_DEFAULT=91xxxxxxxxxxxx

# ===========================
# DATABASE CONFIGURATION
# ===========================

# SQLite database URL (local development)
# Production: Change to PostgreSQL
# Format: sqlite:///./gvp_watch.db
DATABASE_URL=sqlite:///./gvp_watch.db

# ===========================
# LOGGING CONFIGURATION
# ===========================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ===========================
# SCHEDULER CONFIGURATION
# ===========================

# How often to check for reminders and auto-resolutions (in hours)
# Default: 1 hour
REMINDER_CHECK_INTERVAL_HOURS=1

# Reminder timeout for missing photo/location (AWAITING_PHOTO state)
# Citizen is nudged after this many hours if data is incomplete
AWAITING_PHOTO_REMINDER_HOURS=2

# ===========================
# WEB FRONTEND CONFIGURATION
# ===========================

# Admin panel key (change this in production!)
ADMIN_KEY=gvp-admin-2024

# Frontend dev server URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ===========================
# DEBUG MODE
# ===========================

# Set to true for verbose logging and development features
DEBUG=False
